# Medical SAM2 Demo Configuration

# Set to 'true' to use Python script for actual model inference
USE_PYTHON_SEGMENTATION=true

# Hugging Face model download URLs
# Upload your model files to Hugging Face, then add the raw download URLs here
MEDICAL_MODEL_URL=https://huggingface.co/Selena1919/ProZoneSAM2/resolve/main/best_mean3d_model.pth
SAM_MODEL_URL=https://huggingface.co/Selena1919/ProZoneSAM2/resolve/main/sam2_hiera_small.pt

# Railway Bucket endpoint for sample images (exposed to the browser)
# Example: https://your-bucket.railway.app
NEXT_PUBLIC_BUCKET_ENDPOINT=
